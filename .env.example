# App Mode: "saas" or "standalone"
# - saas: Hosted version with subscriptions, vouchers, cloud sync
# - standalone: Self-hosted, all features included, no cloud connection
MBT_MODE=saas

# Stripe (only needed for saas mode)
# Get keys from https://dashboard.stripe.com/test/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Database
DATABASE_URL=postgresql://mbt:mbt_secret_2026@localhost:5432/mbt

# Auth
JWT_SECRET=generate-a-random-string-here

# App
PUBLIC_APP_URL=https://mybalancetracker.co.uk

# Admin
ADMIN_SECRET=change-this-to-something-secure
